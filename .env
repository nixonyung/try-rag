PATH_TO_RAW_DATA_FOLDER=./data/raw/
PATH_TO_PROCESSED_DATA_FOLDER=./data/processed/v1/
PATH_TO_HISTORY_FOLDER=./history/

# CHUNKER_MODEL_NAME="isaacus/kanon-2-tokenizer"
CHUNK_SIZE=1024
CHUNK_OVERLAP=0.1

# DENSE_EMB_MODEL_CONFIG=["fastembed", "jinaai/jina-embeddings-v2-small-en"]
# SPARSE_EMB_MODEL_CONFIG=["fastembed", "prithivida/Splade_PP_en_v1"]
BATCH_SIZE=32

RETRIEVAL_SCORE_THRESHOLD=0.2
RETRIEVAL_LIMIT=100

# LLM_CHUNKING_MODEL_NAME="hf.co/unsloth/granite-4.1-3b-GGUF:UD-Q6_K_XL"
LLM_CHUNKING_MODEL_NAME="hf.co/unsloth/gemma-4-E4B-it-qat-GGUF:UD-Q4_K_XL"
# LLM_CHUNKING_MODEL_NAME="hf.co/bartowski/ibm-granite_granite-4.1-8b-GGUF:Q6_K_L"
# LLM_QUERY_MODEL_NAME="hf.co/bartowski/ibm-granite_granite-4.1-8b-GGUF:Q6_K_L"
LLM_QUERY_MODEL_NAME="hf.co/unsloth/granite-4.1-8b-GGUF:UD-Q6_K_XL"
LLM_CHUNKING_INSTRUCTION_PATH=./system_instructions/chunking.md
LLM_QUERY_INSTRUCTION_PATH=./system_instructions/query.md
LLM_TEMPERATURE=0.0
LLM_THINKING=off
LLM_DEFAULT_NUM_CTX=32768